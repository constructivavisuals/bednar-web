---
import Gallery from '../components/Gallery.astro';
import Reveal from '../components/Reveal.astro';
import { getContent } from '../content';
import { navLabel, type Locale } from '../i18n/config';
import { imgSeries } from '../assets/images';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const c = getContent(locale);

const items = imgSeries('ooc').map((src, i) => ({
  src,
  alt: `Out of Control — ${i + 1}`,
}));
---

<section class="ooc section-pad">
  <div class="ooc__grid">
    <div class="ooc__text">
      <Reveal as="p" class="eyebrow">{navLabel('ooc', locale)}</Reveal>
      <Reveal as="h1" class="section-title">Out of Control</Reveal>
      <div class="ooc__prose">
        {c.ooc.paragraphs.map((p) => <Reveal as="p" class="prose-serif">{p}</Reveal>)}
      </div>
    </div>

    <div class="ooc__gallery">
      <Reveal>
        <Gallery items={items} columns={3} />
      </Reveal>
    </div>
  </div>
</section>

<style>
  .ooc__grid {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    max-width: 1300px;
    margin-inline: auto;
  }
  @media (min-width: 960px) {
    .ooc__grid {
      grid-template-columns: minmax(260px, 0.8fr) 1.4fr;
      align-items: start;
    }
    /* Galerie drží fixní, scrolluje jen text vedle */
    .ooc__gallery {
      position: sticky;
      top: 6rem;
      align-self: start;
    }
  }
  .ooc__prose {
    margin-top: 1.75rem;
  }
</style>
