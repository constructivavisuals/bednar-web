---
import Gallery from '../components/Gallery.astro';
import Reveal from '../components/Reveal.astro';
import { getContent } from '../content';
import { navLabel, type Locale } from '../i18n/config';
import { imgSeries } from '../assets/images';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const c = getContent(locale);

const items = imgSeries('glass').map((src, i) => ({
  src,
  alt: `${c.glass.heading} — ${i + 1}`,
}));
---

<section class="glass section-pad">
  <div class="glass__grid">
    <div class="glass__text">
      <Reveal as="p" class="eyebrow">{navLabel('glass', locale)}</Reveal>
      <Reveal as="h1" class="section-title">{c.glass.heading}</Reveal>
      <div class="glass__prose">
        {c.glass.paragraphs.map((p) => <Reveal as="p" class="prose-serif">{p}</Reveal>)}
      </div>
    </div>

    <div class="glass__gallery">
      <Reveal>
        <Gallery items={items} columns={2} />
      </Reveal>
    </div>
  </div>
</section>

<style>
  .glass__grid {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    max-width: 1300px;
    margin-inline: auto;
  }
  @media (min-width: 960px) {
    .glass__grid {
      grid-template-columns: minmax(260px, 0.8fr) 1.4fr;
      align-items: start;
    }
    /* Text drží nahoře při scrollu galerie */
    .glass__text {
      position: sticky;
      top: 6rem;
    }
  }
  .glass__prose {
    margin-top: 1.75rem;
  }
  @media (prefers-reduced-motion: reduce) {
    .glass__text {
      position: static;
    }
  }
</style>
