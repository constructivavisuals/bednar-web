---
import Hero from '../components/Hero.astro';
import { getContent } from '../content';
import { localizedPath, type Locale } from '../i18n/config';
import { img } from '../assets/images';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const c = getContent(locale);
const bioHref = localizedPath('bio', locale);

const posterAlt =
  locale === 'cs'
    ? 'Modrý abstraktní obraz malovaný na kalené sklo'
    : 'Blue abstract painting on tempered glass';
---

<Hero
  poster={img('hero-blue')}
  posterAlt={posterAlt}
  video="/video/hero-aftermovie.mp4"
  eyebrow={c.home.eyebrow}
  title={'VÁCLAV BEDNÁŘ <span class="accent">ART</span>'}
  subtitle={c.home.subtitle}
/>

<section class="home-cta" id="dal">
  <a class="home-cta__link" href={bioHref} data-reveal>
    {c.ui.moreAboutAuthor}
    <span aria-hidden="true">→</span>
  </a>
</section>

<style>
  .home-cta {
    display: flex;
    justify-content: center;
    padding: clamp(4rem, 12vh, 8rem) 1.5rem;
  }
  .home-cta__link {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    letter-spacing: 0.02em;
    color: var(--color-paper);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid color-mix(in oklab, var(--color-paper) 35%, transparent);
    transition:
      gap 0.3s var(--ease-out-soft),
      border-color 0.3s var(--ease-out-soft);
  }
  .home-cta__link span {
    color: var(--color-accent);
    transition: transform 0.3s var(--ease-out-soft);
  }
  .home-cta__link:hover {
    gap: 1.25rem;
    border-color: var(--color-accent);
  }
  .home-cta__link:hover span {
    transform: translateX(4px);
  }
  @media (prefers-reduced-motion: reduce) {
    .home-cta__link,
    .home-cta__link span {
      transition: none;
    }
  }
</style>
