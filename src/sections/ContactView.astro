---
import SectionBg from '../components/SectionBg.astro';
import Reveal from '../components/Reveal.astro';
import { getContent } from '../content';
import { navLabel, type Locale } from '../i18n/config';
import { img } from '../assets/images';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const c = getContent(locale);

const telHref = 'tel:' + c.contact.phone.replace(/\s+/g, '');
const mailHref = 'mailto:' + c.contact.email;
---

<SectionBg image={img('contact-bg')} alt={navLabel('contact', locale)} parallax={0.18} align="center" scrim={0.6}>
  <div class="contact">
    <div class="contact__card" data-reveal-group>
      <Reveal as="h1" class="section-title contact__title">{navLabel('contact', locale)}</Reveal>
      <ul class="contact__list">
        <Reveal as="li">
          <a href={mailHref}>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 5h18v14H3z" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="m3 6 9 7 9-7" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
            <span>{c.contact.email}</span>
          </a>
        </Reveal>
        <Reveal as="li">
          <a href={c.contact.instagram.href} target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.6"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/></svg>
            <span>{c.contact.instagram.label}</span>
          </a>
        </Reveal>
        <Reveal as="li">
          <a href={c.contact.facebook.href} target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 8h2.5V5H14c-2 0-3.2 1.3-3.2 3.3V10H8.5v3h2.3v8h3v-8h2.3l.4-3h-2.7V8.6c0-.4.3-.6.9-.6Z" fill="currentColor"/></svg>
            <span>{c.contact.facebook.label}</span>
          </a>
        </Reveal>
        <Reveal as="li">
          <a href={telHref}>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 3h3l1.5 5L8 9.5a12 12 0 0 0 6.5 6.5L16 14l5 1.5V19a2 2 0 0 1-2 2A16 16 0 0 1 4 5a2 2 0 0 1 2-2Z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
            <span>{c.contact.phone}</span>
          </a>
        </Reveal>
      </ul>
    </div>
  </div>
</SectionBg>

<style>
  .contact {
    width: 100%;
    display: flex;
    justify-content: flex-end;
    padding: clamp(5rem, 14vh, 9rem) 0;
  }
  .contact__card {
    max-width: 420px;
  }
  .contact__title {
    margin-bottom: 2.5rem;
  }
  .contact__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .contact__list a {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-sans);
    font-size: clamp(1.05rem, 1.8vw, 1.3rem);
    color: var(--color-paper);
    transition: color 0.25s var(--ease-out-soft);
  }
  .contact__list svg {
    width: 26px;
    height: 26px;
    flex-shrink: 0;
    color: var(--color-accent-soft);
    transition: transform 0.25s var(--ease-out-soft);
  }
  .contact__list a:hover {
    color: var(--color-accent-soft);
  }
  .contact__list a:hover svg {
    transform: scale(1.12);
  }
  @media (max-width: 720px) {
    .contact {
      justify-content: center;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .contact__list a,
    .contact__list svg {
      transition: none;
    }
  }
</style>
