---
import Base from '../layouts/Base.astro';
---

<Base title="Václav Bednář ART">
  <main class="flex min-h-svh flex-col items-center justify-center gap-10 px-6 py-24 text-center">
    <p class="text-xs uppercase tracking-[0.35em] text-[var(--color-muted)]">
      Scaffold · krok 1
    </p>

    <h1 class="u-hero">
      VÁCLAV BEDNÁŘ <span class="text-[var(--color-accent)]">ART</span>
    </h1>

    <p class="u-display max-w-[20ch] text-balance text-[var(--color-muted)]">
      Malba na kalené sklo
    </p>

    <div class="prose-serif mt-6 max-w-[60ch] text-left">
      <p>
        Ukázka serifového čteného textu — pro bio, esej a rozhovor. Tmavá
        galerijní výztuž, hodně negativního prostoru, klid. Barvy obrazů budou
        svítit na téměř černém pozadí.
      </p>
    </div>

    <span
      class="mt-4 inline-block rounded-full border border-[var(--color-ink-line)] px-4 py-2 text-sm text-[var(--color-muted)]"
    >
      Tailwind · View Transitions · TypeScript — připraveno
    </span>
  </main>
</Base>
