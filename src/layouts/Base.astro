---
import { ClientRouter } from 'astro:transitions';
import '@fontsource/archivo-black'; // wordmark (prozatímní; finální font z letáku později)
import '@fontsource-variable/space-grotesk';
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600-italic.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = 'Václav Bednář ART',
  description = 'Václav Bednář — výtvarník. Malba na kalené sklo, abstrakce, Out of Control.',
  lang = 'cs',
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Plynulé přechody mezi stránkami -->
    <ClientRouter />

    <!-- Před vykreslením: pokud poběží animace, skryj reveal prvky přes CSS (žádný flash).
         Bez JS / při reduced-motion se třída nenastaví a obsah je rovnou viditelný. -->
    <script is:inline>
      if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('has-motion');
      }
    </script>
  </head>
  <body>
    <slot />

    <!-- Globální smooth scroll + scroll animace (reduced-motion aware) -->
    <script>
      import '../scripts/motion.ts';
    </script>
  </body>
</html>
