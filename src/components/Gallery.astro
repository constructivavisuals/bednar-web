---
// Responsivní masonry galerie náhledů. Klik na položku → PhotoSwipe (smooth zoom).
// Náhledy přes astro:assets (lazy, blur-up). Velký formát se generuje přes getImage.
import { getImage } from 'astro:assets';
import BlurImage from './BlurImage.astro';
import type { ImageMetadata } from 'astro';

export interface GalleryItem {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}

interface Props {
  items: GalleryItem[];
  /** max počet sloupců na širokém displeji (default 3) */
  columns?: number;
  class?: string;
}

const { items, columns = 3, class: className } = Astro.props;

// Velký formát pro lightbox + rozměry pro PhotoSwipe (data-pswp-width/height).
const prepared = await Promise.all(
  items.map(async (it) => {
    const targetW = Math.min(it.src.width, 2000);
    const large = await getImage({ src: it.src, width: targetW });
    const w = targetW;
    const h = Math.round((it.src.height / it.src.width) * targetW);
    return { ...it, largeSrc: large.src, w, h };
  })
);
---

<div
  class:list={['gallery', className]}
  data-gallery
  style={`--cols:${columns};`}
>
  {
    prepared.map((it) => (
      <a
        class="gallery__item"
        href={it.largeSrc}
        data-pswp-width={it.w}
        data-pswp-height={it.h}
        target="_blank"
        rel="noreferrer"
      >
        <figure class="gallery__figure">
          <BlurImage src={it.src} alt={it.alt} sizes="(max-width: 700px) 100vw, 33vw" class="gallery__img" />
          {it.caption && <figcaption class="gallery__caption">{it.caption}</figcaption>}
        </figure>
      </a>
    ))
  }
</div>

<style>
  .gallery {
    columns: var(--cols);
    column-gap: clamp(0.75rem, 1.5vw, 1.25rem);
  }
  @media (max-width: 1024px) {
    .gallery { columns: 2; }
  }
  @media (max-width: 600px) {
    .gallery { columns: 1; }
  }

  .gallery__item {
    display: block;
    break-inside: avoid;
    margin-bottom: clamp(0.75rem, 1.5vw, 1.25rem);
    border-radius: 4px;
    overflow: hidden;
    background: var(--color-ink-soft);
  }
  .gallery__figure {
    margin: 0;
    position: relative;
  }
  .gallery__figure :global(.gallery__img) {
    transition: transform 0.5s var(--ease-out-soft);
  }
  .gallery__item:hover .gallery__figure :global(.gallery__img) {
    transform: scale(1.04);
  }
  .gallery__caption {
    position: absolute;
    inset: auto 0 0 0;
    padding: 1.5rem 1rem 0.75rem;
    font-size: 0.8rem;
    color: var(--color-paper);
    background: linear-gradient(to top, color-mix(in oklab, var(--color-ink) 85%, transparent), transparent);
    opacity: 0;
    transition: opacity 0.35s var(--ease-out-soft);
  }
  .gallery__item:hover .gallery__caption {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery__figure :global(.gallery__img),
    .gallery__caption {
      transition: none;
    }
    .gallery__item:hover .gallery__figure :global(.gallery__img) {
      transform: none;
    }
  }
</style>

<script>
  import '../scripts/gallery.ts';
</script>
