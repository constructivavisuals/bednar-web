---
// Celoplošný hero. Video pozadí (autoplay, muted, loop, playsinline) s poster
// fallbackem (BlurImage). Přes něj wordmark/titulek + volitelný podtitul.
// Tmavý gradientový scrim pro čitelnost, jemný scroll cue dole.
// Reduced-motion: video se nepřehrává, zůstává statický poster.
import BlurImage from './BlurImage.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  poster: ImageMetadata;
  posterAlt: string;
  video?: string;
  eyebrow?: string;
  title: string;
  subtitle?: string;
}

const { poster, posterAlt, video, eyebrow, title, subtitle } = Astro.props;
---

<section class:list={['hero', { 'hero--drift': !video }]}>
  <div class="hero__media">
    <BlurImage src={poster} alt={posterAlt} loading="eager" sizes="100vw" class="hero__poster" />
    {
      video && (
        <video
          class="hero__video"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          data-hero-video
        >
          <source src={video} type="video/mp4" />
        </video>
      )
    }
  </div>

  <div class="hero__scrim" aria-hidden="true"></div>

  <div class="hero__content">
    {eyebrow && <p class="hero__eyebrow" data-hero-fade>{eyebrow}</p>}
    <h1 class="hero__title u-hero" data-hero-title set:html={title} />
    {subtitle && <p class="hero__subtitle" data-hero-fade>{subtitle}</p>}
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
  }
  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__media :global(.hero__poster) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  /* Pomalý ken-burns drift na poster, když hero nemá video (jen transform). */
  .hero--drift :global(.hero__poster) {
    animation: hero-drift 26s ease-in-out infinite alternate;
    will-change: transform;
  }
  @keyframes hero-drift {
    from {
      transform: scale(1.04) translate3d(0, 0, 0);
    }
    to {
      transform: scale(1.12) translate3d(-1.6%, -1.2%, 0);
    }
  }
  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1s var(--ease-out-soft);
  }
  .hero__video[data-playing] {
    opacity: 1;
  }

  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(120% 80% at 50% 35%, transparent 40%, color-mix(in oklab, var(--color-ink) 70%, transparent)),
      linear-gradient(to bottom, color-mix(in oklab, var(--color-ink) 35%, transparent), color-mix(in oklab, var(--color-ink) 75%, transparent));
  }

  .hero__content {
    position: relative;
    z-index: 2;
    padding: 1.5rem;
    max-width: 60rem;
  }
  .hero__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0 0 1.5rem;
  }
  .hero__title {
    margin: 0;
  }
  .hero__title :global(.accent) {
    color: var(--color-accent);
  }
  .hero__subtitle {
    margin: 1.75rem 0 0;
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 2vw, 1.6rem);
    color: color-mix(in oklab, var(--color-paper) 88%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__video { transition: none; }
    .hero--drift :global(.hero__poster) { animation: none; }
  }
</style>

<script>
  // Reduced-motion: video nepřehrávej, nech poster. Jinak fade-in po rozjetí.
  function initHeroVideo() {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    document.querySelectorAll<HTMLVideoElement>('video[data-hero-video]').forEach((v) => {
      if (reduce) {
        v.removeAttribute('autoplay');
        v.pause();
        return;
      }
      const show = () => v.setAttribute('data-playing', '');
      if (v.readyState >= 3) show();
      v.addEventListener('playing', show, { once: true });
      v.play?.().catch(() => {/* autoplay blokován → zůstane poster */});
    });
  }
  initHeroVideo();
  document.addEventListener('astro:page-load', initHeroVideo);
</script>
