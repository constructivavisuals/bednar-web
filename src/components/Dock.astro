---
// macOS-style dock: spodní lišta „app" ikon sekcí s magnifikací pod kurzorem.
// Jen transform (GPU), rAF-throttled. Reduced-motion / dotyk → statické, bez zvětšení.
import { sections, localizedPath, navLabel, type Locale, type SectionKey } from '../i18n/config';

interface Props {
  locale: Locale;
  sectionKey: SectionKey;
}
const { locale, sectionKey } = Astro.props;

// Ikona + tlumená barva dlaždice (sladěná, decentní paleta). Jemný dvoutón pro hloubku.
const icons: Record<SectionKey, { color: string; from: string; path: string }> = {
  home: {
    color: '#4f6f9c',
    from: '#6b89b4',
    path: '<path d="M4.6 11.4 12 5.2l7.4 6.2"/><path d="M6.6 10.2V18.8h10.8V10.2"/>',
  },
  bio: {
    color: '#3f8079',
    from: '#5b9b94',
    path: '<circle cx="12" cy="8.4" r="3"/><path d="M6.2 18.6a5.8 5.8 0 0 1 11.6 0"/>',
  },
  reference: {
    color: '#65608c',
    from: '#837ea8',
    path: '<rect x="6.6" y="4.2" width="10.8" height="15.6" rx="2.2"/><path d="M9.4 9h5.2M9.4 12.5h5.2M9.4 16h3.6"/>',
  },
  glass: {
    color: '#3f7c98',
    from: '#5c97b2',
    path: '<path d="M12 4.4 19.6 12 12 19.6 4.4 12Z"/>',
  },
  ooc: {
    color: '#9c6471',
    from: '#b9818d',
    path: '<path d="M4.7 11.3 11.3 4.7H18a1 1 0 0 1 1 1v6.7l-6.6 6.6a1.2 1.2 0 0 1-1.7 0L4.7 13a1.2 1.2 0 0 1 0-1.7Z"/><circle cx="14.6" cy="9.4" r="1.2"/>',
  },
  studio: {
    color: '#a08a55',
    from: '#bda572',
    path: '<path d="M12 4.2a7.8 7.8 0 1 0 1 15.5c1.1 0 1.6-1 1.3-1.9-.3-1.1.5-2.1 1.7-2.1H18a3 3 0 0 0 3-3c0-4.3-4-8.5-9-8.5Z"/><circle cx="8" cy="11.6" r="1"/><circle cx="10.4" cy="8.2" r="1"/><circle cx="14.4" cy="8.2" r="1"/>',
  },
  news: {
    color: '#5a8a6e',
    from: '#76a78a',
    path: '<path d="M5 10.4v3.2l8.2 3.6V6.8z"/><path d="M14.4 9.6a3.4 3.4 0 0 1 0 4.8"/>',
  },
  contact: {
    color: '#a06a5b',
    from: '#bd8676',
    path: '<rect x="4.6" y="6" width="14.8" height="12" rx="2.4"/><path d="m5.4 8 6.6 4.6L18.6 8"/>',
  },
};

const items = sections; // home + 7 sekcí, v pořadí
---

<nav class="dock" aria-label="Navigace" data-dock>
  <ul class="dock__list">
    {
      items.map((s) => {
        const active = s.key === sectionKey;
        const ic = icons[s.key];
        const label = navLabel(s.key, locale);
        return (
          <li class="dock__cell">
            <a
              class:list={['dock__item', { 'dock__item--active': active }]}
              href={localizedPath(s.key, locale)}
              aria-label={label}
              aria-current={active ? 'page' : undefined}
              data-dock-item
            >
              <span class="dock__tip" aria-hidden="true">{label}</span>
              <span class="dock__icon" style={`--c:${ic.color};--c2:${ic.from}`}>
                <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={ic.path} />
              </span>
              <span class="dock__dot" aria-hidden="true" />
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

<style>
  .dock {
    position: fixed;
    left: 50%;
    bottom: clamp(0.75rem, 2vh, 1.5rem);
    transform: translateX(-50%);
    z-index: 60;
    max-width: calc(100vw - 1.5rem);
  }
  .dock__list {
    display: flex;
    align-items: flex-end;
    gap: clamp(0.3rem, 0.8vw, 0.55rem);
    margin: 0;
    padding: 0.5rem 0.7rem;
    list-style: none;
    border-radius: 22px;
    background: color-mix(in oklab, var(--color-ink-soft) 72%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-paper) 12%, transparent);
    box-shadow:
      0 1px 0 color-mix(in oklab, var(--color-paper) 14%, transparent) inset,
      0 18px 50px -12px rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    /* visible (ne auto) — jinak by overflow ořízl tooltip nad lištou */
    overflow: visible;
  }
  .dock__cell {
    display: flex;
  }

  .dock__item {
    position: relative;
    display: block;
    transform-origin: bottom center;
    will-change: transform;
    /* JS plynule mění transform; přechod jen pro návrat do klidu. */
    transition: transform 0.18s var(--ease-out-soft);
  }

  .dock__icon {
    display: grid;
    place-items: center;
    width: clamp(38px, 5.4vw, 46px);
    height: clamp(38px, 5.4vw, 46px);
    border-radius: 28%;
    background: linear-gradient(180deg, var(--c2), var(--c));
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.18) inset,
      0 5px 12px -7px rgba(0, 0, 0, 0.55);
  }
  .dock__icon svg {
    width: 56%;
    height: 56%;
    opacity: 0.95;
  }

  /* Aktivní tečka pod ikonou */
  .dock__dot {
    position: absolute;
    left: 50%;
    bottom: -6px;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-paper);
    transform: translateX(-50%) scale(0);
    transition: transform 0.2s var(--ease-out-soft);
  }
  .dock__item--active .dock__dot {
    transform: translateX(-50%) scale(1);
  }

  /* Tooltip s názvem stránky nad ikonou (macOS styl) */
  .dock__tip {
    position: absolute;
    left: 50%;
    bottom: calc(100% + 14px);
    transform: translateX(-50%) translateY(4px);
    padding: 0.35rem 0.7rem;
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    white-space: nowrap;
    color: var(--color-paper);
    background: color-mix(in oklab, var(--color-ink-soft) 82%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-paper) 14%, transparent);
    box-shadow: 0 8px 22px -10px rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.16s var(--ease-out-soft),
      transform 0.16s var(--ease-out-soft);
  }
  /* Malá šipka dolů */
  .dock__tip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(-1px);
    border: 5px solid transparent;
    border-top-color: color-mix(in oklab, var(--color-ink-soft) 82%, transparent);
  }
  .dock__item:hover .dock__tip,
  .dock__item:focus-visible .dock__tip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* Úzké telefony: zmenši, ať se 8 ikon vejde bez horizontálního scrollu. */
  @media (max-width: 400px) {
    .dock__list {
      gap: 4px;
      padding: 0.45rem 0.5rem;
    }
    .dock__icon {
      width: 34px;
      height: 34px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dock__item,
    .dock__dot,
    .dock__tip {
      transition: none;
    }
  }
</style>

<script>
  // Magnifikace pod kurzorem (jako macOS dock). Jen transform, rAF-throttled.
  let ac: AbortController | null = null;

  function initDock() {
    ac?.abort();
    ac = new AbortController();
    const { signal } = ac;

    const dock = document.querySelector<HTMLElement>('[data-dock]');
    if (!dock) return;
    const items = Array.from(dock.querySelectorAll<HTMLElement>('[data-dock-item]'));
    if (!items.length) return;

    // Bez zvětšení při reduced-motion nebo na dotykových zařízeních (žádný hover).
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const fine = matchMedia('(pointer: fine)').matches;
    if (reduce || !fine) return;

    const SIGMA = 58; // šířka vlivu (px)
    const BOOST = 0.16; // max zvětšení (jen malinko, +16 %)
    const SPREAD = 5; // rozestup sousedů (px)
    const LIFT = 4; // nadzvednutí (px)

    let centers: number[] = [];
    const measure = () => {
      centers = items.map((it) => {
        const r = it.getBoundingClientRect();
        return r.left + r.width / 2;
      });
    };

    let raf = 0;
    let pointerX: number | null = null;
    const apply = () => {
      raf = 0;
      items.forEach((it, i) => {
        if (pointerX == null) {
          it.style.transform = '';
          return;
        }
        const d = pointerX - centers[i];
        const inf = Math.exp(-(d * d) / (2 * SIGMA * SIGMA));
        const scale = 1 + BOOST * inf;
        const tx = -Math.sign(d) * SPREAD * inf;
        const ty = -LIFT * inf;
        it.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
      });
    };
    const schedule = () => {
      if (!raf) raf = requestAnimationFrame(apply);
    };

    measure();
    dock.addEventListener(
      'pointermove',
      (e) => {
        pointerX = e.clientX;
        schedule();
      },
      { signal }
    );
    dock.addEventListener(
      'pointerleave',
      () => {
        pointerX = null;
        schedule();
      },
      { signal }
    );
    window.addEventListener('resize', measure, { signal });
    window.addEventListener('scroll', measure, { signal, passive: true });
  }

  // astro:page-load se spustí i při prvním načtení → žádný zvlášť volaný init.
  document.addEventListener('astro:page-load', initDock);
  document.addEventListener('astro:before-swap', () => ac?.abort());
</script>
