---
// macOS-style dock: spodní lišta „app" ikon sekcí s magnifikací pod kurzorem.
// Ikony = vlastní PNG dlaždice (frosted glass) v src/assets/images/icons/.
// Magnifikace jen transform (GPU), rAF-throttled. Reduced-motion / dotyk → statické.
import { Image } from 'astro:assets';
import { sections, localizedPath, navLabel, type Locale, type SectionKey } from '../i18n/config';
import type { ImageMetadata } from 'astro';

interface Props {
  locale: Locale;
  sectionKey: SectionKey;
}
const { locale, sectionKey } = Astro.props;

// Načti ikony podle názvu (home.png, bio.png, …).
const iconMods = import.meta.glob<{ default: ImageMetadata }>('../assets/images/icons/*.png', {
  eager: true,
});
const iconByKey: Record<string, ImageMetadata> = {};
for (const p in iconMods) {
  const name = p.split('/').pop()!.replace('.png', '');
  iconByKey[name] = iconMods[p].default;
}
---

<nav class="dock" aria-label="Navigace" data-dock>
  <ul class="dock__list">
    {
      sections.map((s) => {
        const active = s.key === sectionKey;
        const label = navLabel(s.key, locale);
        const icon = iconByKey[s.key];
        return (
          <li class="dock__cell">
            <a
              class:list={['dock__item', { 'dock__item--active': active }]}
              href={localizedPath(s.key, locale)}
              aria-label={label}
              aria-current={active ? 'page' : undefined}
              data-dock-item
            >
              <span class="dock__tip" aria-hidden="true">{label}</span>
              <span class="dock__icon">
                {icon && <Image src={icon} alt="" width={112} height={112} loading="eager" />}
              </span>
              <span class="dock__dot" aria-hidden="true" />
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

<style>
  .dock {
    position: fixed;
    left: 50%;
    bottom: clamp(0.75rem, 2vh, 1.5rem);
    transform: translateX(-50%);
    z-index: 60;
    max-width: calc(100vw - 1.5rem);
  }
  .dock__list {
    display: flex;
    align-items: flex-end;
    gap: clamp(0.3rem, 0.8vw, 0.55rem);
    margin: 0;
    padding: 0.5rem 0.7rem;
    list-style: none;
    border-radius: 22px;
    background: color-mix(in oklab, var(--color-ink-soft) 72%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-paper) 12%, transparent);
    box-shadow:
      0 1px 0 color-mix(in oklab, var(--color-paper) 14%, transparent) inset,
      0 18px 50px -12px rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    /* visible (ne auto) — jinak by overflow ořízl tooltip nad lištou */
    overflow: visible;
  }
  .dock__cell {
    display: flex;
  }

  .dock__item {
    position: relative;
    display: block;
    transform-origin: bottom center;
    will-change: transform;
    transition: transform 0.18s var(--ease-out-soft);
  }

  .dock__icon {
    display: block;
    width: clamp(40px, 5.6vw, 50px);
    height: clamp(40px, 5.6vw, 50px);
    filter: drop-shadow(0 5px 10px rgba(0, 0, 0, 0.45));
  }
  .dock__icon :global(img) {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Aktivní tečka pod ikonou */
  .dock__dot {
    position: absolute;
    left: 50%;
    bottom: -6px;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-paper);
    transform: translateX(-50%) scale(0);
    transition: transform 0.2s var(--ease-out-soft);
  }
  .dock__item--active .dock__dot {
    transform: translateX(-50%) scale(1);
  }

  /* Tooltip s názvem stránky nad ikonou (macOS styl) */
  .dock__tip {
    position: absolute;
    left: 50%;
    bottom: calc(100% + 14px);
    transform: translateX(-50%) translateY(4px);
    padding: 0.35rem 0.7rem;
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    white-space: nowrap;
    color: var(--color-paper);
    background: color-mix(in oklab, var(--color-ink-soft) 82%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-paper) 14%, transparent);
    box-shadow: 0 8px 22px -10px rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.16s var(--ease-out-soft),
      transform 0.16s var(--ease-out-soft);
  }
  .dock__tip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(-1px);
    border: 5px solid transparent;
    border-top-color: color-mix(in oklab, var(--color-ink-soft) 82%, transparent);
  }
  .dock__item:hover .dock__tip,
  .dock__item:focus-visible .dock__tip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* Úzké telefony: zmenši, ať se 8 ikon vejde bez horizontálního scrollu. */
  @media (max-width: 400px) {
    .dock__list {
      gap: 4px;
      padding: 0.45rem 0.5rem;
    }
    .dock__icon {
      width: 36px;
      height: 36px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dock__item,
    .dock__dot,
    .dock__tip {
      transition: none;
    }
  }
</style>

<script>
  // Magnifikace pod kurzorem (jako macOS dock). Jen transform, rAF-throttled.
  let ac: AbortController | null = null;

  function initDock() {
    ac?.abort();
    ac = new AbortController();
    const { signal } = ac;

    const dock = document.querySelector<HTMLElement>('[data-dock]');
    if (!dock) return;
    const items = Array.from(dock.querySelectorAll<HTMLElement>('[data-dock-item]'));
    if (!items.length) return;

    // Bez zvětšení při reduced-motion nebo na dotykových zařízeních (žádný hover).
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const fine = matchMedia('(pointer: fine)').matches;
    if (reduce || !fine) return;

    const SIGMA = 58; // šířka vlivu (px)
    const BOOST = 0.16; // max zvětšení (jen malinko, +16 %)
    const SPREAD = 5; // rozestup sousedů (px)
    const LIFT = 4; // nadzvednutí (px)

    let centers: number[] = [];
    const measure = () => {
      centers = items.map((it) => {
        const r = it.getBoundingClientRect();
        return r.left + r.width / 2;
      });
    };

    let raf = 0;
    let pointerX: number | null = null;
    const apply = () => {
      raf = 0;
      items.forEach((it, i) => {
        if (pointerX == null) {
          it.style.transform = '';
          return;
        }
        const d = pointerX - centers[i];
        const inf = Math.exp(-(d * d) / (2 * SIGMA * SIGMA));
        const scale = 1 + BOOST * inf;
        const tx = -Math.sign(d) * SPREAD * inf;
        const ty = -LIFT * inf;
        it.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
      });
    };
    const schedule = () => {
      if (!raf) raf = requestAnimationFrame(apply);
    };

    measure();
    dock.addEventListener('pointermove', (e) => { pointerX = e.clientX; schedule(); }, { signal });
    dock.addEventListener('pointerleave', () => { pointerX = null; schedule(); }, { signal });
    window.addEventListener('resize', measure, { signal });
    window.addEventListener('scroll', measure, { signal, passive: true });
  }

  document.addEventListener('astro:page-load', initDock);
  document.addEventListener('astro:before-swap', () => ac?.abort());
</script>
