---
// Horní lišta (menu bar): wordmark vlevo, přepínač jazyků vpravo.
// Hlavní navigace je v dolním Docku (viz Dock.astro).
import { localizedPath, type Locale, type SectionKey } from '../i18n/config';
import LangSwitcher from './LangSwitcher.astro';

interface Props {
  locale: Locale;
  sectionKey: SectionKey;
}

const { locale, sectionKey } = Astro.props;
const homeHref = localizedPath('home', locale);
---

<header class="topbar">
  <a class="wordmark" href={homeHref} aria-label="Václav Bednář ART — domů">
    VÁCLAV BEDNÁŘ <span class="wordmark__accent">ART</span>
  </a>
  <LangSwitcher sectionKey={sectionKey} locale={locale} />
</header>

<style>
  .topbar {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: clamp(1rem, 2.5vw, 1.75rem) clamp(1.25rem, 4vw, 3rem);
    background: linear-gradient(
      to bottom,
      color-mix(in oklab, var(--color-ink) 80%, transparent),
      transparent
    );
  }

  .wordmark {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(0.95rem, 1.6vw, 1.15rem);
    letter-spacing: 0.14em;
    color: var(--color-paper);
    white-space: nowrap;
    transition: opacity 0.25s var(--ease-out-soft);
  }
  .wordmark:hover {
    opacity: 0.8;
  }
  .wordmark__accent {
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .wordmark {
      transition: none;
    }
  }
</style>
